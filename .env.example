# ==============================================
# JDE VISIONARY - Environment Variables
# ==============================================

# Database (MySQL - Local Application Data)
DATABASE_URL=mysql://user:password@localhost:3306/jde_visionary

# JDE MSSQL Connection (For Purchase Orders)
# These are the JDE tables:
# - CRPDTA.F4301 (Purchase Order Header)
# - CRPDTA.F4311 (Purchase Order Detail)
# - CRPDTA.F0101 (Address Book - Supplier Names)
MSSQL_HOST=your_jde_server_host
MSSQL_PORT=1433
MSSQL_USER=your_jde_username
MSSQL_PASSWORD=your_jde_password
MSSQL_DATABASE=CRPDTA

# OAuth & Auth
VITE_APP_ID=your_app_id
JWT_SECRET=your_jwt_secret
OAUTH_SERVER_URL=your_oauth_server_url
OWNER_OPEN_ID=your_owner_openid

# AI Configuration
OPENAI_API_KEY=your_openai_api_key

# Forge API (Optional)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

